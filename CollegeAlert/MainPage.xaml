<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CollegeAlert.MainPage"
             BackgroundColor="White"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto">
        
        <!-- Header: "єБезпека" with Logo -->
        <Grid Grid.Row="0" Padding="25,55,25,15" ColumnDefinitions="Auto,*,Auto">
            <Image Grid.Column="0" Source="college_logo.png" WidthRequest="32" HeightRequest="32" VerticalOptions="Center" Margin="0,0,10,0"/>
            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                <Label Text="єБезпека" FontSize="20" FontAttributes="Bold" TextColor="#1E293B" FontFamily="OpenSansBold"/>
                <Label Text="Екстренні сповіщення та підтримка" FontSize="11" TextColor="#94A3B8"/>
            </VerticalStackLayout>
            <Image Grid.Column="2" Source="bell_icon.png" WidthRequest="24" HeightRequest="24" VerticalOptions="Center"/>
        </Grid>

        <!-- Content Area -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="0" Padding="20,5">
                
                <!-- Location Selection (Compact Segmented Control Style) -->
                <Border StrokeShape="RoundRectangle 16" BackgroundColor="#F8FAFC" Padding="15,10" StrokeThickness="0" Margin="0,5,0,15">
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Label Grid.Column="0" Text="Корпус:" VerticalOptions="Center" TextColor="#64748B" FontSize="14"/>
                            <Label Grid.Column="1" x:Name="BuildingLabel" Text="Верхній корпус" FontAttributes="Bold" TextColor="#1E293B" VerticalOptions="Center" Margin="10,0,0,0"/>
                            <HorizontalStackLayout Grid.Column="2" Spacing="4" BackgroundColor="#E2E8F0" Padding="4" HeightRequest="36" VerticalOptions="Center">
                                <RoundRectangle CornerRadius="12" Fill="Transparent"/>
                                <Button x:Name="UpperTab" Text="В" Clicked="OnBuildingSelected" BackgroundColor="White" TextColor="#1E293B" CornerRadius="8" FontSize="14" WidthRequest="40" HeightRequest="28" Padding="0"/>
                                <Button x:Name="LowerTab" Text="Н" Clicked="OnBuildingSelected" BackgroundColor="Transparent" TextColor="#64748B" CornerRadius="8" FontSize="14" WidthRequest="40" HeightRequest="28" Padding="0"/>
                            </HorizontalStackLayout>
                        </Grid>
                        
                        <BoxView HeightRequest="1" Color="#E2E8F0"/>

                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Label Grid.Column="0" Text="Поверх:" VerticalOptions="Center" TextColor="#64748B" FontSize="14"/>
                            <Label Grid.Column="1" x:Name="FloorLabel" Text="1 поверх" FontAttributes="Bold" TextColor="#1E293B" VerticalOptions="Center" Margin="10,0,0,0"/>
                            <HorizontalStackLayout Grid.Column="2" Spacing="4" BackgroundColor="#E2E8F0" Padding="4" HeightRequest="36" VerticalOptions="Center">
                                <RoundRectangle CornerRadius="12" Fill="Transparent"/>
                                <Button x:Name="F1" Text="1" Clicked="OnFloorSelected" BackgroundColor="White" TextColor="#1E293B" CornerRadius="8" FontSize="14" WidthRequest="32" HeightRequest="28" Padding="0"/>
                                <Button x:Name="F2" Text="2" Clicked="OnFloorSelected" BackgroundColor="Transparent" TextColor="#64748B" CornerRadius="8" FontSize="14" WidthRequest="32" HeightRequest="28" Padding="0"/>
                                <Button x:Name="F3" Text="3" Clicked="OnFloorSelected" BackgroundColor="Transparent" TextColor="#64748B" CornerRadius="8" FontSize="14" WidthRequest="32" HeightRequest="28" Padding="0"/>
                            </HorizontalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Huge SOS Section matching screenshot -->
                <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                    <Grid WidthRequest="260" HeightRequest="260">
                        <!-- Red Glow Halo -->
                        <Ellipse Fill="#FCA5A5" Opacity="0.3" StrokeThickness="0" WidthRequest="260" HeightRequest="260"/>
                        <!-- Animated Progress Ring -->
                        <Ellipse x:Name="ProgressRing" Stroke="#DC2626" StrokeThickness="6" StrokeDashArray="675,675" StrokeDashOffset="675" Fill="Transparent" WidthRequest="220" HeightRequest="220" HorizontalOptions="Center" VerticalOptions="Center" Rotation="-90"/>
                        
                        <Border x:Name="AlarmButton" BackgroundColor="#EF4444" WidthRequest="200" HeightRequest="200" StrokeShape="RoundRectangle 100" HorizontalOptions="Center" VerticalOptions="Center" StrokeThickness="0">
                            <Border.Shadow><Shadow Brush="#EF4444" Offset="0,10" Radius="20" Opacity="0.4"/></Border.Shadow>
                            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" InputTransparent="True" Spacing="5">
                                <Label Text="ТРИВОГА" FontSize="28" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
                                <Label Text="Натисніть і утримуйте&#x0a;3 секунди" FontSize="12" TextColor="#FEF2F2" HorizontalOptions="Center" HorizontalTextAlignment="Center" Opacity="0.9"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>

                <!-- Status Block matching screenshot -->
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center" Margin="0,15,0,0">
                    <Border BackgroundColor="#E2E8F0" StrokeThickness="0" StrokeShape="RoundRectangle 12" WidthRequest="24" HeightRequest="24" HorizontalOptions="Center">
                        <Image Source="check_icon.png" WidthRequest="14" HeightRequest="14" HorizontalOptions="Center" VerticalOptions="Center" Opacity="0.8"/>
                    </Border>
                    <Label Text="Зараз активних тривог немає" FontSize="15" FontAttributes="Bold" TextColor="#1E293B" HorizontalOptions="Center"/>
                    <Label Text="Дякуємо, що дбаєте про безпеку" FontSize="13" TextColor="#94A3B8" HorizontalOptions="Center"/>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Links -->
        <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="15" Padding="20" Margin="0,0,0,10">
            <Border Grid.Column="0" StrokeShape="RoundRectangle 16" BackgroundColor="White" Stroke="#E2E8F0" StrokeThickness="1" Padding="15,10">
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                    <Image Source="info_icon.png" WidthRequest="16"/>
                    <Label Text="Про додаток" FontSize="12" FontAttributes="Bold" TextColor="#2563EB" VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </Border>
            <Border Grid.Column="1" StrokeShape="RoundRectangle 16" BackgroundColor="White" Stroke="#E2E8F0" StrokeThickness="1" Padding="15,10">
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                    <Image Source="bell_icon.png" WidthRequest="16"/>
                    <Label Text="Контакти підтримки" FontSize="12" FontAttributes="Bold" TextColor="#2563EB" VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </Border>
        </Grid>

    </Grid>
</ContentPage>
