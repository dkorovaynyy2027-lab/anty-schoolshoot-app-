<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CollegeAlert.MainPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#EAF2FF, Dark=#050B16}">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{AppThemeBinding Light=#F9FCFF, Dark=#06101F}" Offset="0.0" />
                <GradientStop Color="{AppThemeBinding Light=#E9F2FF, Dark=#081A31}" Offset="0.45" />
                <GradientStop Color="{AppThemeBinding Light=#FFF7E1, Dark=#1B1608}" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollView>
            <VerticalStackLayout Padding="18,16,18,26" Spacing="14">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                    <Border WidthRequest="64"
                            HeightRequest="64"
                            StrokeThickness="1"
                            Stroke="{AppThemeBinding Light=#FFFFFF, Dark=#2B446A}"
                            BackgroundColor="{AppThemeBinding Light=#DFFFFFFF, Dark=#B0101D33}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="22" />
                        </Border.StrokeShape>
                        <Image Source="college_logo.png"
                               WidthRequest="46"
                               HeightRequest="46"
                               Aspect="AspectFit"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>

                    <VerticalStackLayout Grid.Column="1"
                                         Spacing="3"
                                         VerticalOptions="Center">
                        <Label Text="eБезпека"
                               FontSize="30"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#0E172A, Dark=#F8FBFF}" />
                        <Label x:Name="HeaderSubtitle"
                               Text="Коледж онлайн - тихий режим"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#5E6B82, Dark=#AABAD5}" />
                    </VerticalStackLayout>

                    <Button x:Name="ThemeButton"
                            Grid.Column="2"
                            Text="Авто"
                            Clicked="OnThemeClicked"
                            HeightRequest="46"
                            MinimumWidthRequest="68"
                            CornerRadius="23"
                            Padding="14,0"
                            FontAttributes="Bold"
                            BackgroundColor="{AppThemeBinding Light=#EFFFFFFF, Dark=#B0101D33}"
                            BorderColor="{AppThemeBinding Light=#FFFFFF, Dark=#2B446A}"
                            BorderWidth="1"
                            TextColor="{AppThemeBinding Light=#1F5FCB, Dark=#91BEFF}" />
                </Grid>

                <Border Padding="14"
                        StrokeThickness="1"
                        Stroke="{AppThemeBinding Light=#FFFFFF, Dark=#243C61}"
                        BackgroundColor="{AppThemeBinding Light=#DFFFFFFF, Dark=#A00B172A}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="28" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Spacing="2">
                                <Label x:Name="SystemTitle"
                                       Text="Система готова"
                                       FontSize="22"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#101827, Dark=#F8FBFF}" />
                                <Label x:Name="SystemSubtitle"
                                       Text="Остання перевірка: щойно"
                                       FontSize="13"
                                       TextColor="{AppThemeBinding Light=#64748B, Dark=#AABAD5}" />
                            </VerticalStackLayout>
                            <Border Grid.Column="1"
                                    Padding="12,8"
                                    StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light=#E7F9EF, Dark=#102D20}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="18" />
                                </Border.StrokeShape>
                                <Label x:Name="LiveBadge"
                                       Text="● LIVE"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#17884B, Dark=#87F2A7}" />
                            </Border>
                        </Grid>

                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                            <Border Padding="10,8"
                                    StrokeThickness="1"
                                    Stroke="{AppThemeBinding Light=#DBE8FF, Dark=#28466F}"
                                    BackgroundColor="{AppThemeBinding Light=#F6FAFF, Dark=#101D33}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="18" />
                                </Border.StrokeShape>
                                <Label Text="🏢 Корпус Б"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       HorizontalTextAlignment="Center"
                                       TextColor="{AppThemeBinding Light=#28476F, Dark=#D9E7FF}" />
                            </Border>
                            <Border Grid.Column="1"
                                    Padding="10,8"
                                    StrokeThickness="1"
                                    Stroke="{AppThemeBinding Light=#DBE8FF, Dark=#28466F}"
                                    BackgroundColor="{AppThemeBinding Light=#F6FAFF, Dark=#101D33}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="18" />
                                </Border.StrokeShape>
                                <Label Text="📍 3 поверх"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       HorizontalTextAlignment="Center"
                                       TextColor="{AppThemeBinding Light=#28476F, Dark=#D9E7FF}" />
                            </Border>
                            <Border Grid.Column="2"
                                    Padding="10,8"
                                    StrokeThickness="1"
                                    Stroke="{AppThemeBinding Light=#FFE3A0, Dark=#6D5420}"
                                    BackgroundColor="{AppThemeBinding Light=#FFF8E4, Dark=#2E240D}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="18" />
                                </Border.StrokeShape>
                                <Label x:Name="VibrationChip"
                                       Text="📳 Помірна"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       HorizontalTextAlignment="Center"
                                       TextColor="{AppThemeBinding Light=#8B6500, Dark=#FFE08A}" />
                            </Border>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Grid ColumnDefinitions="*,*"
                      Padding="4"
                      ColumnSpacing="4"
                      BackgroundColor="{AppThemeBinding Light=#DCEAFF, Dark=#0E1A2D}">
                    <Grid.Clip>
                        <RoundRectangleGeometry CornerRadius="25" Rect="0,0,600,58" />
                    </Grid.Clip>
                    <Button x:Name="StudentRoleButton"
                            Text="🎓 Студент"
                            Clicked="OnStudentRoleClicked"
                            HeightRequest="50"
                            CornerRadius="21"
                            FontAttributes="Bold"
                            BackgroundColor="#2467DE"
                            TextColor="#FFFFFF" />
                    <Button x:Name="AdminRoleButton"
                            Grid.Column="1"
                            Text="🛡 Адміністрація"
                            Clicked="OnAdminRoleClicked"
                            HeightRequest="50"
                            CornerRadius="21"
                            FontAttributes="Bold"
                            BackgroundColor="Transparent"
                            TextColor="{AppThemeBinding Light=#38506F, Dark=#A8B7D3}" />
                </Grid>

                <Border Padding="18"
                        StrokeThickness="1"
                        Stroke="{AppThemeBinding Light=#FFFFFF, Dark=#243C61}"
                        BackgroundColor="{AppThemeBinding Light=#DFFFFFFF, Dark=#990B172A}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="34" />
                    </Border.StrokeShape>
                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Spacing="3">
                                <Label x:Name="AlertTitle"
                                       Text="Тихе сповіщення"
                                       FontSize="24"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#101827, Dark=#F8FBFF}" />
                                <Label x:Name="AlertSubtitle"
                                       Text="Утримуйте кнопку, щоб передати сигнал черговому"
                                       FontSize="13"
                                       TextColor="{AppThemeBinding Light=#64748B, Dark=#AABAD5}" />
                            </VerticalStackLayout>
                            <Border Grid.Column="1"
                                    WidthRequest="58"
                                    HeightRequest="58"
                                    StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light=#F0F6FF, Dark=#10213A}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="20" />
                                </Border.StrokeShape>
                                <Label x:Name="ModeBadge"
                                       Text="OK"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light=#2467DE, Dark=#91BEFF}" />
                            </Border>
                        </Grid>

                        <Grid Grid.Row="1" HeightRequest="328">
                            <Border WidthRequest="298"
                                    HeightRequest="298"
                                    StrokeThickness="1"
                                    Stroke="{AppThemeBinding Light=#E4EDFA, Dark=#243C61}"
                                    BackgroundColor="{AppThemeBinding Light=#70FFFFFF, Dark=#66101D33}"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="149" />
                                </Border.StrokeShape>
                            </Border>

                            <Border WidthRequest="260"
                                    HeightRequest="260"
                                    StrokeThickness="1"
                                    Stroke="{AppThemeBinding Light=#FFFFFF, Dark=#314E78}"
                                    BackgroundColor="{AppThemeBinding Light=#5FFFFFFF, Dark=#4418273F}"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="130" />
                                </Border.StrokeShape>
                            </Border>

                            <Border x:Name="HoldProgress"
                                    WidthRequest="298"
                                    HeightRequest="298"
                                    Stroke="#FF4A4A"
                                    StrokeThickness="8"
                                    Opacity="0"
                                    BackgroundColor="#00FFFFFF"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"
                                    Rotation="-90">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="149" />
                                </Border.StrokeShape>
                            </Border>

                            <Button x:Name="AlarmButton"
                                    WidthRequest="224"
                                    HeightRequest="224"
                                    CornerRadius="112"
                                    Pressed="OnAlarmPressed"
                                    Released="OnAlarmReleased"
                                    Text="🚨&#10;ТРИВОГА&#10;утримуйте 3 с"
                                    FontSize="19"
                                    FontAttributes="Bold"
                                    TextColor="#FFFFFF"
                                    BackgroundColor="#E93D3D"
                                    Shadow="{Shadow Brush=#663A1515, Offset='0,18', Radius=28, Opacity=0.42}" />
                        </Grid>

                        <Border Grid.Row="2"
                                Padding="14"
                                StrokeThickness="1"
                                Stroke="{AppThemeBinding Light=#E0EAFE, Dark=#28466F}"
                                BackgroundColor="{AppThemeBinding Light=#F7FAFF, Dark=#0F1D33}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="22" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Label x:Name="InstructionEmoji"
                                       Text="✅"
                                       FontSize="34"
                                       VerticalOptions="Center" />
                                <VerticalStackLayout Grid.Column="1" Spacing="2">
                                    <Label x:Name="PrimaryStatusLabel"
                                           Text="Активних тривог немає"
                                           FontSize="17"
                                           FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light=#101827, Dark=#F8FBFF}" />
                                    <Label x:Name="SecondaryStatusLabel"
                                           Text="Система працює разом з офіційними процедурами безпеки"
                                           FontSize="13"
                                           TextColor="{AppThemeBinding Light=#64748B, Dark=#AABAD5}" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <VerticalStackLayout x:Name="StudentPanel" Spacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Мій статус"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#101827, Dark=#F8FBFF}" />
                        <Label Grid.Column="1"
                               Text="1 дотик"
                               FontSize="12"
                               TextColor="{AppThemeBinding Light=#64748B, Dark=#AABAD5}"
                               VerticalOptions="Center" />
                    </Grid>

                    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,*" RowSpacing="12" ColumnSpacing="12">
                        <Button Text="🟢 Я в безпеці"
                                Clicked="OnSafeClicked"
                                HeightRequest="64"
                                CornerRadius="22"
                                BackgroundColor="{AppThemeBinding Light=#EBFAF0, Dark=#123622}"
                                BorderColor="{AppThemeBinding Light=#BFECCC, Dark=#2E7C4A}"
                                BorderWidth="1"
                                TextColor="{AppThemeBinding Light=#24743E, Dark=#8AF0A8}"
                                FontAttributes="Bold" />
                        <Button Grid.Column="1"
                                Text="🆘 Допомога"
                                Clicked="OnNeedHelpClicked"
                                HeightRequest="64"
                                CornerRadius="22"
                                BackgroundColor="{AppThemeBinding Light=#FFF0F0, Dark=#3A1519}"
                                BorderColor="{AppThemeBinding Light=#F4B8B8, Dark=#8B343A}"
                                BorderWidth="1"
                                TextColor="{AppThemeBinding Light=#C73B3B, Dark=#FF9B9B}"
                                FontAttributes="Bold" />
                        <Button Grid.Row="1"
                                Text="📍 Не в корпусі"
                                Clicked="OnAwayClicked"
                                HeightRequest="64"
                                CornerRadius="22"
                                BackgroundColor="{AppThemeBinding Light=#EEF5FF, Dark=#10213A}"
                                BorderColor="{AppThemeBinding Light=#C9DAFF, Dark=#31588B}"
                                BorderWidth="1"
                                TextColor="{AppThemeBinding Light=#2467DE, Dark=#91BEFF}"
                                FontAttributes="Bold" />
                        <Button Grid.Row="1"
                                Grid.Column="1"
                                Text="👁 Отримано"
                                Clicked="OnReceivedClicked"
                                HeightRequest="64"
                                CornerRadius="22"
                                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#101C31}"
                                BorderColor="{AppThemeBinding Light=#D7E4FA, Dark=#28466F}"
                                BorderWidth="1"
                                TextColor="{AppThemeBinding Light=#38506F, Dark=#D7E6FF}"
                                FontAttributes="Bold" />
                    </Grid>

                    <Button Text="📄 Переглянути інструкції"
                            Clicked="OnInstructionsClicked"
                            HeightRequest="58"
                            CornerRadius="22"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#101C31}"
                            BorderColor="{AppThemeBinding Light=#D7E4FA, Dark=#28466F}"
                            BorderWidth="1"
                            TextColor="{AppThemeBinding Light=#2467DE, Dark=#91BEFF}"
                            FontAttributes="Bold" />
                </VerticalStackLayout>

                <VerticalStackLayout x:Name="AdminPanel" IsVisible="False" Spacing="12">
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                        <Border Padding="12"
                                StrokeThickness="1"
                                Stroke="{AppThemeBinding Light=#D7E4FA, Dark=#28466F}"
                                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#101C31}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="22" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="1">
                                <Label x:Name="ReceivedCountLabel" Text="0" FontSize="26" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#2467DE, Dark=#91BEFF}" />
                                <Label Text="отримали" FontSize="11" TextColor="{AppThemeBinding Light=#64748B, Dark=#AABAD5}" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="1"
                                Padding="12"
                                StrokeThickness="1"
                                Stroke="{AppThemeBinding Light=#F4B8B8, Dark=#8B343A}"
                                BackgroundColor="{AppThemeBinding Light=#FFF7F7, Dark=#2C1117}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="22" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="1">
                                <Label x:Name="HelpCountLabel" Text="0" FontSize="26" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#C73B3B, Dark=#FF9B9B}" />
                                <Label Text="допомога" FontSize="11" TextColor="{AppThemeBinding Light=#64748B, Dark=#AABAD5}" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="2"
                                Padding="12"
                                StrokeThickness="1"
                                Stroke="{AppThemeBinding Light=#FFE3A0, Dark=#6D5420}"
                                BackgroundColor="{AppThemeBinding Light=#FFF8E4, Dark=#2E240D}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="22" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="1">
                                <Label x:Name="CoverageCountLabel" Text="0%" FontSize="26" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#8B6500, Dark=#FFE08A}" />
                                <Label Text="охоплення" FontSize="11" TextColor="{AppThemeBinding Light=#64748B, Dark=#AABAD5}" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <Border Padding="14"
                            StrokeThickness="1"
                            Stroke="{AppThemeBinding Light=#FFFFFF, Dark=#243C61}"
                            BackgroundColor="{AppThemeBinding Light=#DFFFFFFF, Dark=#990B172A}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="26" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="12">
                            <Label Text="Пульт оповіщення"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#101827, Dark=#F8FBFF}" />

                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                                <Button x:Name="ScopeBuildingButton" Text="Корпус" Clicked="OnScopeBuildingClicked" HeightRequest="46" CornerRadius="18" FontAttributes="Bold" />
                                <Button x:Name="ScopeCampusButton" Grid.Column="1" Text="Територія" Clicked="OnScopeCampusClicked" HeightRequest="46" CornerRadius="18" FontAttributes="Bold" />
                                <Button x:Name="ScopeAllButton" Grid.Column="2" Text="Коледж" Clicked="OnScopeAllClicked" HeightRequest="46" CornerRadius="18" FontAttributes="Bold" />
                            </Grid>

                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                                <Button x:Name="VibeSilentButton" Text="🔕 Тихо" Clicked="OnSilentVibeClicked" HeightRequest="46" CornerRadius="18" FontAttributes="Bold" />
                                <Button x:Name="VibeModerateButton" Grid.Column="1" Text="📳 Вібро" Clicked="OnModerateVibeClicked" HeightRequest="46" CornerRadius="18" FontAttributes="Bold" />
                                <Button x:Name="VibeLoudButton" Grid.Column="2" Text="🔊 Гучно" Clicked="OnLoudVibeClicked" HeightRequest="46" CornerRadius="18" FontAttributes="Bold" />
                            </Grid>

                            <Button Text="🚨 Підтвердити і розіслати"
                                    Clicked="OnConfirmIncidentClicked"
                                    HeightRequest="58"
                                    CornerRadius="22"
                                    BackgroundColor="#E93D3D"
                                    TextColor="#FFFFFF"
                                    FontAttributes="Bold" />
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <Button Text="🧪 Навчальна"
                                        Clicked="OnDrillClicked"
                                        HeightRequest="56"
                                        CornerRadius="22"
                                        BackgroundColor="{AppThemeBinding Light=#FFF6D8, Dark=#3B2C0C}"
                                        BorderColor="{AppThemeBinding Light=#F1D36B, Dark=#8B711F}"
                                        BorderWidth="1"
                                        TextColor="{AppThemeBinding Light=#8A6700, Dark=#FFE28A}"
                                        FontAttributes="Bold" />
                                <Button Grid.Column="1"
                                        Text="✅ Скасувати"
                                        Clicked="OnCancelIncidentClicked"
                                        HeightRequest="56"
                                        CornerRadius="22"
                                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#101C31}"
                                        BorderColor="{AppThemeBinding Light=#D7E4FA, Dark=#28466F}"
                                        BorderWidth="1"
                                        TextColor="{AppThemeBinding Light=#38506F, Dark=#D7E6FF}"
                                        FontAttributes="Bold" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <Border Padding="14"
                            StrokeThickness="1"
                            Stroke="{AppThemeBinding Light=#D7E4FA, Dark=#28466F}"
                            BackgroundColor="{AppThemeBinding Light=#F8FBFF, Dark=#0F1D33}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="24" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Журнал подій"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#101827, Dark=#F8FBFF}" />
                            <Label x:Name="EventLogLabel"
                                   Text="17:00  Система очікує сигналів&#10;17:00  Авторизація користувачів коледжу активна"
                                   FontSize="12"
                                   LineHeight="1.25"
                                   TextColor="{AppThemeBinding Light=#526179, Dark=#AABAD5}" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <Border Padding="14"
                        StrokeThickness="1"
                        Stroke="{AppThemeBinding Light=#D7E4FA, Dark=#28466F}"
                        BackgroundColor="{AppThemeBinding Light=#CFFFFFFF, Dark=#70101C31}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>
                    <Label Text="Система доповнює офіційні процедури безпеки: фізичну сигналізацію, охорону, адміністрацію та екстрені служби."
                           FontSize="12"
                           LineHeight="1.2"
                           TextColor="{AppThemeBinding Light=#64748B, Dark=#AABAD5}" />
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
