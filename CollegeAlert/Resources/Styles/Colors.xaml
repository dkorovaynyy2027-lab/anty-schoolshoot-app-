<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="Primary">#2467DE</Color>
    <Color x:Key="Secondary">#F1F5F9</Color>
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>
    
    <Color x:Key="AppBackground">#F8FAFC</Color>
    <Color x:Key="AppSurface">#FFFFFF</Color>
    <Color x:Key="AppAccent">#2467DE</Color>
    <Color x:Key="AppDanger">#E93D3D</Color>
    <Color x:Key="AppSuccess">#22C55E</Color>
    <Color x:Key="AppTextPrimary">#1E293B</Color>
    <Color x:Key="AppTextSecondary">#64748B</Color>
    <Color x:Key="AppBorder">#E2E8F0</Color>

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackground}"/>
    <SolidColorBrush x:Key="AppSurfaceBrush" Color="{StaticResource AppSurface}"/>
    <SolidColorBrush x:Key="AppAccentBrush" Color="{StaticResource AppAccent}"/>
    <SolidColorBrush x:Key="AppTextPrimaryBrush" Color="{StaticResource AppTextPrimary}"/>
    <SolidColorBrush x:Key="AppTextSecondaryBrush" Color="{StaticResource AppTextSecondary}"/>
</ResourceDictionary>